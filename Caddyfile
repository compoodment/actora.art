# actora.art — production
actora.art, www.actora.art {
	root * /home/compadmin/sites/actora.art/production/dist
	file_server

	# chat API proxy
	handle /api/* {
		reverse_proxy 127.0.0.1:4322
	}

	# admin stats proxy
	handle /admin/stats {
		reverse_proxy 127.0.0.1:4322
	}

	# security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer-when-downgrade
	}

	# cache static assets
	@static path *.css *.js *.svg *.png *.jpg *.ico *.woff2
	header @static Cache-Control "public, max-age=31536000, immutable"

	# html pages: short cache, revalidate often
	@html path *.html /
	header @html Cache-Control "public, max-age=0, must-revalidate"
}