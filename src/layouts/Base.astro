---
import '../styles/global.css';
import '../styles/terminal.css';
import '../styles/chat.css';

interface Props {
  title: string;
  description?: string;
  noWrapper?: boolean;
}

const { title, description = 'actora.art', noWrapper = false } = Astro.props;
const site = Astro.site;
const canonical = site ? new URL(Astro.url.pathname, site) : undefined;
const sitemap = site ? new URL('/sitemap-index.xml', site) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    {canonical && <link rel="canonical" href={canonical.toString()} />}
    {sitemap && <link rel="sitemap" href={sitemap.toString()} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="actora.art" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical.toString()} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    {noWrapper ? (
      <slot />
    ) : (
      <div class="page">
        <slot />
        <footer class="page-footer">
          <a href="/">↳ back</a>
        </footer>
      </div>
    )}
  </body>
</html>