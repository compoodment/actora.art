---
import Base from '../layouts/Base.astro';
---

<Base title="actora.art" description="projects, experiments, and things worth keeping">
  <main class="index">
    <header class="index-header">
      <h1>actora.art</h1>
    </header>

    <section class="index-section">
      <h2>projects</h2>
      <ul class="index-list">
        <li>
          <a href="/projects/actora">actora</a>
          <span class="index-note">— ongoing</span>
        </li>
      </ul>
    </section>

    <section class="index-section">
      <h2>lab</h2>
      <ul class="index-list">
        <li class="index-dim">nothing here yet</li>
      </ul>
    </section>

    <section class="index-section">
      <h2>links</h2>
      <ul class="index-list">
        <li>
          <a href="https://github.com/compoodment" target="_blank" rel="noopener">github</a>
        </li>
      </ul>
    </section>
  </main>
</Base>

<style>
  .index-header h1 {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-xl);
  }

  .index-section {
    margin-bottom: var(--spacing-lg);
  }

  .index-section h2 {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--spacing-sm);
  }

  .index-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .index-list li {
    font-size: 0.9rem;
  }

  .index-note {
    color: var(--color-text-dim);
    font-size: 0.8rem;
  }

  .index-dim {
    color: var(--color-text-dim);
    font-style: italic;
  }
</style>