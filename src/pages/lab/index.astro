---
import Base from '../../layouts/Base.astro';
---

<Base title="lab — actora.art" description="experiments and unfinished things">
  <main class="lab">
    <header class="lab-header">
      <h1>lab</h1>
      <p class="lab-dim">experiments and unfinished things.</p>
    </header>

    <section class="lab-list">
      <a href="/lab/particles" class="lab-item">
        <span class="lab-item-name">particles</span>
        <span class="lab-item-desc">particle flow — move your cursor</span>
      </a>
    </section>
  </main>
</Base>

<style>
  .lab-header h1 {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-xs);
  }

  .lab-dim {
    color: var(--color-text-dim);
    font-size: 0.85rem;
    margin-bottom: var(--spacing-xl);
  }

  .lab-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lab-item {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 0;
    border-bottom: 1px solid #1a1a1a;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .lab-item:hover {
    border-color: #444;
  }

  .lab-item-name {
    font-weight: 500;
    font-size: 0.9rem;
  }

  .lab-item-desc {
    color: var(--color-text-dim);
    font-size: 0.75rem;
    margin-top: 0.15rem;
  }
</style>