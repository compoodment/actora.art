---
import Base from '../../layouts/Base.astro';
---

<Base title="lab — actora.art" description="experiments and unfinished things">
  <main class="lab">
    <header class="page-header">
      <h1 class="page-title page-title-section">lab</h1>
    </header>

    <section class="lab-list page-section">
      <a href="/lab/particles" class="lab-item">
        <span class="lab-item-name">particles</span>
        <span class="lab-item-desc">visual particle simulator</span>
      </a>
      <a href="/lab/wall" class="lab-item">
        <span class="lab-item-name">the wall</span>
        <span class="lab-item-desc">a wall. draw on it.</span>
      </a>
    </section>
  </main>
</Base>

<style>
  .lab-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .lab-item {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .lab-item:hover {
    border-color: #444;
  }

  .lab-item-name {
    font-weight: 500;
  }

  .lab-item-desc {
    color: var(--color-text-dim);
    font-size: 0.75rem;
    margin-top: 0.15rem;
  }
</style>