---
import Base from '../../layouts/Base.astro';
---

<Base title="projects — actora.art" description="External projects.">
  <main class="projects">
    <header class="page-header">
      <h1 class="page-title page-title-section">projects</h1>
    </header>

    <section class="projects-list page-section">
      <a href="/projects/actora" class="project-link">
        <span class="project-name">actora</span>
        <span class="project-status">ongoing</span>
      </a>
    </section>

  </main>
</Base>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .project-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
  }

  .project-link:hover {
    color: var(--color-accent);
  }

  .project-name {
    font-weight: 500;
  }

  .project-status {
    color: var(--color-text-dim);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
